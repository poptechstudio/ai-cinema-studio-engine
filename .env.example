# AI Cinema Studio Engine — Environment Variables
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# Required: OpenAI (embeddings for RAG)
OPENAI_API_KEY=sk-your-key-here

# Required: Qdrant vector DB
QDRANT_API_KEY=your-qdrant-api-key

# Required: fal.ai model gateway (Seedance 2, Nano Banana Pro, etc.)
FAL_KEY=your-fal-key-here

# Optional: ElevenLabs (voice, SFX, music)
ELEVENLABS_API_KEY=

# Optional: HeyGen (avatar video)
HEYGEN_API_KEY=

# Optional: Muapi.ai (Open Generative AI backend, 200+ models)
MUAPI_API_KEY=

# Optional: N8N workflow engine
N8N_API_KEY=
N8N_BASE_URL=https://workflows.poptechstudio.ai
